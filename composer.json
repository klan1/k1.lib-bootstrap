{
    "name": "klan1/k1.lib-bootstrap",
    "description": "Bootstrap 5 components built on k1lib.html",
    "license": "Apache-2.0",
    "type": "library",
    "version": "1.1",
    "homepage": "https://github.com/klan1/k1lib-bootstrap",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Alejandro Trujillo J. (J0hnd03)",
            "homepage": "https://github.com/j0hnd03"
        }
    ],
    "require": {
        "php": "^8.0",
        "klan1/k1.lib-html": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "k1lib\\html\\bootstrap\\": "src/k1lib/html/bootstrap/"
        }
    },
    "scripts": {
        "examples": [
            "Composer\\Config::disableProcessTimeout",
            "php -S localhost:8200 -t examples &",
            "open http://localhost:8200"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^10"
    }
}
