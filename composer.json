{
    "name": "klan1/k1.lib-bootstrap",
    "description": "Bootstrap 5 components built on k1lib.html",
    "license": "Apache-2.0",
    "type": "library",
    "version": "2.1",
    "homepage": "https://github.com/klan1/k1lib-bootstrap",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Alejandro Trujillo J. (J0hnd03)",
            "homepage": "https://github.com/j0hnd03"
        }
    ],
    "require": {
        "php": "^8.2",
        "klan1/k1.lib-html": "v2.x"
    },
    "autoload": {
        "psr-4": {
            "k1lib\\html\\bootstrap\\": "src/klan1/html/bootstrap/",
            "k1lib\\html\\componentes\\": "src/klan1/html/componentes/"
        }
    },
    "scripts": {
        "examples": [
            "Composer\\Config::disableProcessTimeout",
            "php -S localhost:8200 -t examples"
        ]
    }
}