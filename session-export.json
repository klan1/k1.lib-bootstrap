            },
            "output": "  k1.lib-bootstrap - Components Showcase   \n\n[k1.lib-bootstrap](#) Bootstrap 5 Components Showcase\n\nComponents [Alert](#alert) [Badge](#badge) [Breadcrumb](#breadcrumb) [Button Group](#button-group) [Card](#card) [Callout](#callout) [Collapse](#collapse) [Dropdown](#dropdown) [Grid](#grid) [List Group](#list-group) [Menu](#menu) [Modal](#modal) [Nav](#nav) [Navbar](#navbar) [Pagination](#pagination) [Progress](#progress) [Spinner](#spinner) [Table](#table) [Toast](#toast) [Title Bar](#title-bar) [Top Bar](#top-bar)\n\n## Alert\n\nPreview\n\n#### Important Message\n\nCode\n\n`<?php $demo_alert = new alert( 'This is a primary alert—check it out!', 'primary', true ); $demo_alert->set_heading('Important Message'); echo $demo_alert->generate();`\n\n## Badge\n\nPreview\n\nPrimary Secondary Success Danger Warning Info Light Dark Pill Badge\n\nCode\n\n`<?php echo (new badge('Primary'))->generate() . ' '; echo (new badge('Secondary', 'secondary'))->generate() . ' '; echo (new badge('Success', 'success'))->generate() . ' '; echo (new badge('Pill Badge', 'primary', true))->generate();`\n\n## Breadcrumb\n\nPreview\n\n1.  breadcrumb-item [Home](#)\n2.  breadcrumb-item [Library](#)\n3.  breadcrumb-item [Data](#)\n4.  Current Page\n\nCode\n\n`<?php $bread = new breadcrumb([ ['text' => 'Home', 'href' => '#'], ['text' => 'Library', 'href' => '#'], ['text' => 'Data', 'href' => '#'], ['text' => 'Current Page'] ]); echo $bread->generate();`\n\n## Button Group\n\nPreview\n\nLeft Center Right\n\nCode\n\n`<?php $btn1 = new btn('Left', 'btn-primary'); $btn2 = new btn('Center', 'btn-primary'); $btn3 = new btn('Right', 'btn-primary'); $group = new button_group([$btn1, $btn2, $btn3]); echo $group->generate();`\n\n## Card\n\nPreview\n\n##### Card Title\n\n###### Card Subtitle\n\nSome quick example text to build on the card title and make up the bulk of the card's content.\n\n[Go somewhere](#)\n\nCode\n\n`<?php $demo_card = new card( 'Card Title', 'Card Subtitle', 'Some quick example text...' ); $demo_card->body()->append_a('#', 'Go somewhere', 'btn btn-primary'); echo $demo_card->generate();`\n\n## Callout\n\nPreview\n\n###### Callout Title\n\nThis is a dismissible callout message.\n\nCode\n\n`<?php $callout = new callout( 'This is a dismissible callout message.', 'Callout Title', true, 'primary' ); echo $callout->generate();`\n\n## Collapse\n\nPreview\n\nToggle Content\n\nThis is some collapsible content that reveals when you click the button above. It uses Bootstrap's collapse functionality.\n\nYou can put any HTML content here.\n\nCode\n\n`<?php $trigger = new btn('Toggle Content', 'btn-primary'); $collapse_content = '<p>Your content here...</p>'; $collapse = new collapse('demo', $trigger, $collapse_content); echo $trigger->generate() . ' '; echo $collapse->generate();`\n\n## Dropdown\n\nPreview\n\nActions\n\n-   [Action](#)\n-   [Another Action](#)\n\n-   [Separated Link](#)\n\nCode\n\n`<?php $dropdown = new dropdown('Actions', [ ['text' => 'Action', 'href' => '#'], ['text' => 'Another Action', 'href' => '#'], ['divider' => true], ['text' => 'Separated Link', 'href' => '#'] ]); echo $dropdown->generate();`\n\n## Grid\n\nPreview\n\nRow 1, Col 1\n\nRow 1, Col 2\n\nRow 1, Col 3\n\nRow 2, Col 1\n\nRow 2, Col 2\n\nRow 2, Col 3\n\nCode\n\n`<?php $demo_grid = new grid(2, 3); $row1 = $demo_grid->row(1); $row1->general(4)->small(6)->medium(4); $row1->get_child(0)->set_value('Row 1, Col 1'); $row2 = $demo_grid->row(2); $row2->general(4)->small(6)->medium(4); $row2->get_child(0)->set_value('Row 2, Col 1'); echo $demo_grid->generate();`\n\n## List Group\n\nPreview\n\n-   [First item](#)\n-   [Second item](#)\n-   [Third item](#)\n-   Disabled item\n\nCode\n\n`<?php $list = new list_group([ ['text' => 'First item', 'href' => '#'], ['text' => 'Second item', 'href' => '#', 'active' => true], ['text' => 'Third item', 'href' => '#'], ['text' => 'Disabled item', 'disabled' => true] ]); echo $list->generate();`\n\n## Menu\n\nPreview\n\n-   [Home](#)\n-   [About](#)\n-   [Services](#)\n-   [More Services](#)\n    -   [Service A](#)\n    -   [Service B](#)\n-   [Contact](#)\n\nCode\n\n`<?php $demo_menu = new menu('dropdown'); $demo_menu->add_menu_item('#', 'Home'); $demo_menu->add_menu_item('#', 'About'); $submenu = $demo_menu->add_sub_menu('#', 'Services'); $submenu->add_menu_item('#', 'Service A'); echo $demo_menu->generate();`\n\n## Modal\n\nPreview\n\n# Modal Title\n\nThis is the modal body content. You can put any HTML here.\n\nCancel Confirm\n\nCode\n\n`<?php $modal = new modal( 'Modal Title', '<p>This is the modal body content.</p>', 'Cancel', 'Confirm' ); echo $modal->generate();`\n\n## Nav\n\nPreview\n\n-   nav-item [Home](#)\n-   nav-item [Features](#)\n-   nav-item [Pricing](#)\n-   nav-item [Disabled](#)\n\nCode\n\n`<?php $demo_nav = new nav([ ['text' => 'Home', 'href' => '#', 'active' => true], ['text' => 'Features', 'href' => '#'], ['text' => 'Pricing', 'href' => '#'], ], 'pills'); echo $demo_nav->generate();`\n\n## Navbar\n\nPreview\n\n[Brand Name](#)\n\n-   nav-item [Home](#)\n-   nav-item [Link](#)\n-   nav-item [Dropdown](#)\n\nCode\n\n`<?php $demo_navbar = new navbar('Brand Name', 'demoNav', 'light', 'lg'); $nav_links = new nav_component([ ['text' => 'Home', 'href' => '#', 'active' => true], ['text' => 'Link', 'href' => '#'], ], 'nav'); $demo_navbar->add_to_collapse($nav_links); echo $demo_navbar->generate();`\n\n## Pagination\n\nPreview\n\n-   [«](/page?page=2)\n-   [1](/page?page=1)\n-   [2](/page?page=2)\n-   [3](/page?page=3) (current)\n-   [4](/page?page=4)\n-   [5](/page?page=5)\n-   [6](/page?page=6)\n-   [7](/page?page=7)\n-   [8](/page?page=8)\n-   [9](/page?page=9)\n-   [10](/page?page=10)\n-   [»](/page?page=4)\n\nCode\n\n`<?php $pager = new pagination(3, 10, '/page', true); echo $pager->generate();`\n\n## Progress\n\nPreview\n\nCode\n\n`<?php $prog = new progress([ ['value' => 25, 'type' => 'primary'], ['value' => 50, 'type' => 'success', 'striped' => true], ['value' => 75, 'type' => 'warning', 'animated' => true], ['value' => 100, 'type' => 'danger'] ], 20); echo $prog->generate();`\n\n## Spinner\n\nPreview\n\n  \n  \n\nCode\n\n`<?php // Border spinner echo (new spinner('border', 'primary'))->generate(); // Grow spinner echo (new spinner('grow', 'success'))->generate();`\n\n## Table\n\nPreview\n\n1\n\nJohn Doe\n\njohn@example.com\n\nAdmin\n\n2\n\nJane Smith\n\njane@example.com\n\nEditor\n\n3\n\nBob Wilson\n\nbob@example.com\n\nUser\n\nCode\n\n`<?php $table = new table_from_data(); $table->set_data([ ['id' => 1, 'name' => 'John Doe', 'email' => 'john@example.com', 'role' => 'Admin'], ['id' => 2, 'name' => 'Jane Smith', 'email' => 'jane@example.com', 'role' => 'Editor'], ['id' => 3, 'name' => 'Bob Wilson', 'email' => 'bob@example.com', 'role' => 'User'] ]); echo $table->generate();`\n\n## Toast\n\nPreview\n\n×\n\nThis is the toast body message.\n\nCode\n\n`<?php $toast = new toast( 'Notification Header', 'This is the toast body message.', true, 5000 ); echo $toast->generate();`\n\n## Title Bar\n\nPreview\n\nPage Title\n\nCode\n\n`<?php $title_bar = new title_bar('demo-title'); $title_bar->title()->set_value('Page Title'); echo $title_bar->generate();`\n\n## Top Bar\n\nPreview\n\n-   My Application\n-   [Home](#)\n-   [About](#)\n-   [Services](#)\n-   [Contact](#)\n\nCode\n\n`<?php $top = new top_bar('main-top'); $top->title()->set_value('My Application'); $top->menu_left()->add_menu_item('#', 'Home'); $top->menu_left()->add_menu_item('#', 'About'); echo $top->generate();`",
