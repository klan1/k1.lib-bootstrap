   $text_regexp = \"/(\\s*$text\\s*)/\";\n52:         $regexp_match = [];\n53:         if (preg_match($text_regexp, $attribute_value, $regexp_match)) {\n54:             $string_new = str_replace($regexp_match[1], \"\", $attribute_value);\n55:             $this->set_attrib($attribute, $string_new);\n56:             return $string_new;\n57:         } else {\n58:             return $attribute_value;\n59:         }\n60:     }\n61: \n62:     public function append_close_button() {\n63:         $close_button = new button(NULL, \"btn-close\");\n64:         $close_button->set_attrib('data-bs-dismiss', 'alert');\n65:         $close_button->set_attrib(\"aria-label\", \"Close\");\n66:         $this->append_child_tail($close_button);\n67:     }\n68: \n69:     /**\n70:      * @return div\n71:      */\n72:     public function align_center() {\n73:         $this->set_attrib(\"class\", \"align-center\", TRUE);\n74:         return $this;\n75:     }\n76: \n77:     /**\n78:      * @return div\n79:      */\n80:     public function align_left() {\n81:         $this->set_attrib(\"class\", \"align-left\", TRUE);\n82:         return $this;\n83:     }\n84: \n85:     /**\n86:      * @return div\n87:      */\n88:     public function align_right() {\n89:         $this->set_attrib(\"class\", \"align-right\", TRUE);\n90:         return $this;\n91:     }\n92: \n93:     /**\n94:      * @return div\n95:      */\n96:     public function align_justify() {\n97:         $this->set_attrib(\"class\", \"align-justify\", TRUE);\n98:         return $this;\n99:     }\n100: \n101:     /**\n102:      * @return div\n103:      */\n104:     public function general($cols, $clear = FALSE) {\n105:         $this->general = $cols;\n106: \n107:         if ($clear) {\n108:             $this->set_attrib(\"class\", \"col-{$cols}\", (!$clear));\n109:         } else {\n110:             $this->replace_attribute_number(\"class\", \"col\", $cols);\n111:         }\n112: \n113:         return $this;\n114:     }\n115: \n116:     